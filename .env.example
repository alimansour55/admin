# Local dev: http://localhost:5174
VITE_BACKEND_URL=http://localhost:4000

# Vercel / production: Project → Settings → Environment Variables
#   VITE_BACKEND_URL = https://YOUR-DEPLOYED-API.example.com
# Then redeploy (Vite bakes this in at build time).

# Mobile (same Wi-Fi): see MOBILE_ACCESS.md — open http://YOUR_PC_IP:5174 on the phone.
# API is auto-detected as http://YOUR_PC_IP:4000 (no .env change needed).
# First run (Admin PowerShell from repo root): npm run mobile:firewall
